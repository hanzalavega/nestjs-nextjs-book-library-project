generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Student {
  id            Int      @id @default(autoincrement())
  name          String
  email         String   @unique
  phone         String?
  department    String?
  photoUrl      String?
  photoPublicId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Author {
  id        Int      @id @default(autoincrement())
  name      String
  email     String?  @unique
  bio       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
